{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MimirOCR",
  "version": "0.1.8-pre-release",
  "identifier": "io.mrogness.mimirocr",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MimirOCR",
        "width": 1400,
        "height": 900,
        "minWidth": 1400,
        "minHeight": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": [
      "binaries"
    ]
  }
}
