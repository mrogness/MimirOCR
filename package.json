{
  "name": "Mimir",
  "private": true,
  "version": "0.1.11-pre-release",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "bootstrap:windows": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap_windows_packaging.ps1",
    "sidecar:clean": "node scripts/clean_sidecar_artifacts.mjs",
    "sidecar:preflight": "node scripts/check_backend_sidecar_env.mjs",
    "build:sidecar": "yarn sidecar:clean && node scripts/build_backend_sidecar.mjs",
    "release:tag": "node scripts/release_version.mjs",
    "package": "yarn sidecar:preflight && yarn build:sidecar && yarn tauri build",
    "package:mac": "yarn sidecar:preflight && yarn build:sidecar && yarn tauri build --bundles app,dmg && node scripts/zip_macos_app_bundle.mjs",
    "package:windows": "yarn sidecar:preflight && yarn build:sidecar && yarn tauri build --bundles nsis"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "pdfjs-dist": "^6.1.200",
    "vue": "^3.5.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.3.1",
    "vite": "^6.0.3"
  }
}
